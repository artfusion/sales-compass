{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1280px"
		},
		"color": {
			"custom": false,
			"customGradient": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"slug": "ocean-blue",
					"color": "#0077B6",
					"name": "Ocean Blue"
				},
				{
					"slug": "platinum-white",
					"color": "#EAEDED",
					"name": "Platinum White"
				},
				{
					"slug": "base-white",
					"color": "#FFFFFF",
					"name": "White"
				},
				{
					"slug": "gray-900",
					"color": "#111827",
					"name": "Gray 900"
				},
				{
					"slug": "gray-800",
					"color": "#1F2937",
					"name": "Gray 800"
				},
				{
					"slug": "gray-600",
					"color": "#4B5563",
					"name": "Gray 600"
				},
				{
					"slug": "gray-500",
					"color": "#6B7280",
					"name": "Gray 500"
				},
				{
					"slug": "gray-300",
					"color": "#D1D5DB",
					"name": "Gray 300"
				},
				{
					"slug": "gray-200",
					"color": "#E5E7EB",
					"name": "Gray 200"
				},
				{
					"slug": "gray-100",
					"color": "#F3F4F6",
					"name": "Gray 100"
				},
				{
					"slug": "blue-100",
					"color": "#DBEAFE",
					"name": "Blue 100"
				},
				{
					"slug": "accent-yellow",
					"color": "#FBBF24",
					"name": "Accent Yellow"
				},
				{
					"slug": "accent-green",
					"color": "#10B981",
					"name": "Accent Green"
				}
			]
		},
		"typography": {
			"customFontSize": false,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"slug": "inter",
					"name": "Inter",
					"fontFamily": "Inter, sans-serif"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "0.875rem",
					"fluid": false
				},
				{
					"slug": "body",
					"name": "Body",
					"size": "1rem",
					"fluid": false
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1.25rem",
					"fluid": {
						"min": "1.125rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "2rem",
					"fluid": {
						"min": "1.5rem",
						"max": "2rem"
					}
				},
				{
					"slug": "x-large",
					"name": "X-Large",
					"size": "2.5rem",
					"fluid": {
						"min": "1.75rem",
						"max": "2.5rem"
					}
				},
				{
					"slug": "xx-large",
					"name": "XX-Large",
					"size": "3.5rem",
					"fluid": {
						"min": "2rem",
						"max": "3.5rem"
					}
				},
				{
					"slug": "huge",
					"name": "Huge",
					"size": "4rem",
					"fluid": {
						"min": "2.5rem",
						"max": "4rem"
					}
				}
			]
		},
		"spacing": {
			"customSpacingSize": false,
			"defaultSpacingSizes": false,
			"blockGap": true,
			"spacingSizes": [
				{
					"slug": "xs",
					"size": "0.5rem",
					"name": "Extra Small"
				},
				{
					"slug": "sm",
					"size": "1rem",
					"name": "Small"
				},
				{
					"slug": "md",
					"size": "1.5rem",
					"name": "Medium"
				},
				{
					"slug": "lg",
					"size": "2rem",
					"name": "Large"
				},
				{
					"slug": "xl",
					"size": "3rem",
					"name": "X-Large"
				},
				{
					"slug": "2xl",
					"size": "4rem",
					"name": "2X-Large"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base-white)",
			"text": "var(--wp--preset--color--gray-600)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--inter)",
			"fontSize": "var(--wp--preset--font-size--body)",
			"lineHeight": "1.6"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--ocean-blue)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--gray-800)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--ocean-blue)",
					"text": "var(--wp--preset--color--base-white)"
				},
				"border": {
					"radius": "6px"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"right": "1.5rem",
						"bottom": "0.75rem",
						"left": "1.5rem"
					}
				},
				":hover": {
					"color": {
						"background": "#1D4ED8"
					}
				}
			},
			"h1": {
				"color": {
					"text": "var(--wp--preset--color--gray-800)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"color": {
					"text": "var(--wp--preset--color--gray-800)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"color": {
					"text": "var(--wp--preset--color--gray-800)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"color": {
					"text": "var(--wp--preset--color--gray-800)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--inter)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			}
		}
	}
}
